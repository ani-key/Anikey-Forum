# 复制本文件为 .env 并填入你的 Supabase 项目信息
# 位置：Supabase 控制台 → Project Settings → API
#
# 这两个值都是「公开」的（anon key 设计上就允许暴露在前端），
# 真正的数据安全由数据库的行级权限(RLS)保证，schema.sql 已配置好。
#
# 未填写时，网站只展示登录/注册入口，番剧内容不会对未登录用户开放。

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# 可选：Bangumi 访问代理。国内网络无法直连 bgm.tv / api.bgm.tv 时配置。
# API 代理需要兼容 /calendar 和 /v0/... 路径。
# 图片代理支持两种格式：
#   https://your-worker.example.com/image
#   https://your-worker.example.com/image?url={url}
VITE_BANGUMI_API_BASE=
VITE_BANGUMI_IMAGE_PROXY=
